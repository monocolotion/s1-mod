  "SUBTITLE_RECOVERY_REC_GDN_YOUREXOISEQUIPPEDWITH": "^2Gideon: ^7你的外骨骼配备了超速驱动器。需要战术优势时使用它。",
  "SUBTITLE_RECOVERY_REC_ILN1_DONTNEEDTOTRY": "^2Ilona: ^7不需要试。我还是第一名。",
