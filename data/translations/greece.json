  "SUBTITLE_GREECE_GRK_ILN_BLASTTHATGATE": "^2Ilona: ^7炸开那道门，米切尔！",
  "SUBTITLE_GREECE_GRK_ILN_BRAVOHASKEY": "^2Ilona: ^7有钥匙卡。",
  "SUBTITLE_GREECE_GRK_ILN_CANTGETABEAD": "^2Ilona: ^7无法瞄准那个狙击手！我们得靠近塔楼！",
  "SUBTITLE_GREECE_GRK_ILN_CANYOUATLEAST": "^2Ilona: ^7你至少能给我指个方向吗？",
  "SUBTITLE_GREECE_GRK_ILN_CHOOSEYOURTARGET": "^2Ilona: ^7选择你的目标。",
  "SUBTITLE_GREECE_GRK_ILN_CLEAR": "^2Ilona: ^7安全。",
  "SUBTITLE_GREECE_GRK_ILN_COMEONWELL": "^2Ilona: ^7快！我们从后巷包抄他！",
  "SUBTITLE_GREECE_GRK_ILN_COPYTHATALPHA": "^2Ilona: ^7收到，Alpha。米切尔，绕过去掩护中庭的玻璃侧。",
  "SUBTITLE_GREECE_GRK_ILN_DAMMITMITCHELL": "^2Ilona: ^7该死的米切尔，他们发现我们了！",
  "SUBTITLE_GREECE_GRK_ILN_DEPLOYYOURSONICS": "^2Ilona: ^7释放声波武器！",
  "SUBTITLE_GREECE_GRK_ILN_DOITMITCHELL": "^2Ilona: ^7动手，米切尔。",
  "SUBTITLE_GREECE_GRK_ILN_DOWNTHESTAIRS": "^2Ilona: ^7米切尔！下楼梯到后街！我们需要拦截哈迪斯！",
  "SUBTITLE_GREECE_GRK_ILN_DROPEMALPH": "^2Ilona: ^7需要把KVA从那道门引开。能干掉就干掉，或者用车喇叭声分散他们注意力。",
  "SUBTITLE_GREECE_GRK_ILN_DROPTHEGUARD": "^2Ilona: ^7在那守卫报警之前干掉他！",
  "SUBTITLE_GREECE_GRK_ILN_DROPTHEMALL": "^2Ilona: ^7楼梯顶。两个一起干掉，米切尔。",
  "SUBTITLE_GREECE_GRK_ILN_FINDHIM": "^2Ilona: ^7找到他，否则整个任务就泡汤了。",
  "SUBTITLE_GREECE_GRK_ILN_FOLLOWTHEFIRST": "^2Ilona: ^7松散跟踪。然后干掉他。",
  "SUBTITLE_GREECE_GRK_ILN_GETEYESONHADES": "^2Ilona: ^7米切尔，移动WASP，监视哈迪斯的会议。",
  "SUBTITLE_GREECE_GRK_ILN_GETMOVINGHADES": "^2Ilona: ^7米切尔，快走！哈迪斯的会议不到一小时后就要开始了！",
  "SUBTITLE_GREECE_GRK_ILN_GETONITMITCHELL": "^2Ilona: ^7快去做，米切尔！我还在追踪信号源！",
  "SUBTITLE_GREECE_GRK_ILN_GIDEONISINTROUBLE": "^2Ilona: ^7吉迪恩有麻烦了！",
  "SUBTITLE_GREECE_GRK_ILN_GOBLACKUNTIL": "^2Ilona: ^7Alpha，进入静默。WASP将开始行动。",
  "SUBTITLE_GREECE_GRK_ILN_GOODWORK": "^2Ilona: ^7干得好。",
  "SUBTITLE_GREECE_GRK_ILN_GOTASTAMP": "^2Ilona: ^7锁定引爆器频率。稍等，我正在追踪信号源！",
  "SUBTITLE_GREECE_GRK_ILN_HADESISDOWN": "^2Ilona: ^7哈迪斯倒了！Alpha进入确认击杀！",
  "SUBTITLE_GREECE_GRK_ILN_HAVENTLOSTAFISH": "^2Ilona: ^7第一阶段堪称教科书。我们跟踪目标，拿他的钥匙卡，清理安全屋。",
