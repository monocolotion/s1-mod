  "SUBTITLE_GREECE_GRK_GDN_COURTYARDCLEAR": "^2Gideon: ^7庭院安全。",
  "SUBTITLE_GREECE_GRK_GDN_DONTCOCKTHIS": "^2Gideon: ^7别搞砸了，姑娘们。",
  "SUBTITLE_GREECE_GRK_GDN_DONTLETHIMSOUND": "^2Gideon: ^7别让他拉响警报！",
  "SUBTITLE_GREECE_GRK_GDN_HOLDING": "^2Gideon: ^7抓住他了。",
  "SUBTITLE_GREECE_GRK_GDN_HOLDUPNOW": "^2Gideon: ^7等等。现在我们安全了。",
  "SUBTITLE_GREECE_GRK_GDN_KVAISMOVING": "^2Gideon: ^7KVA在移动。",
  "SUBTITLE_GREECE_GRK_GDN_MITCHELLWHAT": "^2Gideon: ^7米切尔，你在干什么？",
  "SUBTITLE_GREECE_GRK_GDN_MOVINGUP": "^2Gideon: ^7前进中。",
  "SUBTITLE_GREECE_GRK_GDN_MUTECHARGEREADY": "^2Gideon: ^7静音炸药就绪。",
  "SUBTITLE_GREECE_GRK_GDN_NICESHOT": "^2Gideon: ^7好枪法。",
  "SUBTITLE_GREECE_GRK_GDN_PICKUPTHEPACE": "^2Gideon: ^7加快速度。",
  "SUBTITLE_GREECE_GRK_GDN_PLACINGMUTE": "^2Gideon: ^7Alpha就位。正在安放静音炸药。",
  "SUBTITLE_GREECE_GRK_GDN_POOLISCLEAR": "^2Gideon: ^7泳池安全。",
  "SUBTITLE_GREECE_GRK_GDN_ROGERDODGER": "^2Gideon: ^7明白。",
  "SUBTITLE_GREECE_GRK_GDN_SCANNINGRETINA": "^2Gideon: ^7扫描视网膜。不匹配。不是哈迪斯！不是哈迪斯！",
  "SUBTITLE_GREECE_GRK_GDN_SHIT": "^2Gideon: ^7操！",
  "SUBTITLE_GREECE_GRK_GDN_SHITMOREKVA": "^2Gideon: ^7操，KVA的无人机起飞了！",
  "SUBTITLE_GREECE_GRK_GDN_SORRYTOINTERRUPT": "^2Gideon: ^7向前靠，伊洛娜。你应该在度蜜月的。",
  "SUBTITLE_GREECE_GRK_GDN_STAIRSARECLEAR": "^2Gideon: ^7楼梯安全。等待WASP。",
  "SUBTITLE_GREECE_GRK_GDN_STICKTOYOUR": "^2Gideon: ^7盯住你的目标，米切尔！",
  "SUBTITLE_GREECE_GRK_GDN_THANKSFORTHE": "^2Gideon: ^7多谢支援。",
  "SUBTITLE_GREECE_GRK_GDN_THATWASACLOSE": "^2Gideon: ^7该死的混蛋。",
  "SUBTITLE_GREECE_GRK_GDN_THISISNT14": "^2Gideon: ^7这不是14街？我们有货物要送到14街。",
  "SUBTITLE_GREECE_GRK_GDN_WAITINGONWASP": "^2Gideon: ^7等待WASP。",
  "SUBTITLE_GREECE_GRK_GDN_WASPWENEED": "^2Gideon: ^7WASP，我们需要掩护！",
  "SUBTITLE_GREECE_GRK_GDN_WECANTJUSTSIT": "^2Gideon: ^7我们不能光坐在这栋楼上，伊洛娜！",
  "SUBTITLE_GREECE_GRK_GDN_WENEEDCOVERING": "^2Gideon: ^7我们需要掩护火力！",
