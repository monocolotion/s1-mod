  "SUBTITLE_GREECE_GRE_ILN_PUSHFORWARDYOJOE": "^2Ilona: ^7继续向前推进！",
  "SUBTITLE_GREECE_GRE_ILN_PUSHFOWARDCONTAIN": "^2Ilona: ^7向前推进！我们需要控制现场！",
  "SUBTITLE_GREECE_GRE_ILN_QUISTALLANDJUMP": "^2Ilona: ^7别磨蹭了，快跳！",
  "SUBTITLE_GREECE_GRE_ILN_READYPLEASE": "^2Ilona: ^7他们来了。准备！",
  "SUBTITLE_GREECE_GRE_ILN_RUNWHITEBOY": "^2Ilona: ^7你怎么不跑？快走！",
  "SUBTITLE_GREECE_GRE_ILN_SETUPAMBUSHTHERE": "^2Ilona: ^7那里！我们可以从那里设伏！",
  "SUBTITLE_GREECE_GRE_ILN_SHITRIGHTKILL": "^2Ilona: ^7操！我们需要毒刺导弹。行动！",
  "SUBTITLE_GREECE_GRE_ILN_SHITTHATSALOTOGROUND": "^2Ilona: ^7操，这么大一片开阔地。你想先跑还是压制火力？",
  "SUBTITLE_GREECE_GRE_ILN_SHITYOUPINGED": "^2Ilona: ^7操。他发现我们了！",
  "SUBTITLE_GREECE_GRE_ILN_SIGNALISCLOSE": "^2Ilona: ^7KVA信号很近。",
  "SUBTITLE_GREECE_GRE_ILN_SNIPERCANTHIT": "^2Ilona: ^7快点，狙击手打不到街上的我们。",
  "SUBTITLE_GREECE_GRE_ILN_SNIPERTOP": "^2Ilona: ^7该死！狙击手瞄准我们了！",
  "SUBTITLE_GREECE_GRE_ILN_STAYCLOSEM": "^2Ilona: ^7保持靠近！",
  "SUBTITLE_GREECE_GRE_ILN_STAYONMESANCHEZ": "^2Ilona: ^7跟着我，米切尔！托雷斯就在前面！",
  "SUBTITLE_GREECE_GRE_ILN_STAYWITHMEGIRL": "^2Ilona: ^7跟着我，米切尔！",
  "SUBTITLE_GREECE_GRE_ILN_STREETSARECLEARPLEASE": "^2Ilona: ^7安全！街道安全！先知，我们正在向哈迪斯推进！",
  "SUBTITLE_GREECE_GRE_ILN_SUPPRESSTHAT": "^2Ilona: ^7米切尔，压制那个狙击手！",
  "SUBTITLE_GREECE_GRE_ILN_TAKESHOTBIGSHOT": "^2Ilona: ^7开枪，米切尔！",
  "SUBTITLE_GREECE_GRE_ILN_THERECHECKHIM": "^2Ilona: ^7那里。检查他。",
  "SUBTITLE_GREECE_GRE_ILN_THEYRECLEARINGOUT": "^2Ilona: ^7他们在清场！",
  "SUBTITLE_GREECE_GRE_ILN_THEYREPULLINGBACK": "^2Ilona: ^7他们在撤退！",
  "SUBTITLE_GREECE_GRE_ILN_THISWAYM": "^2Ilona: ^7这边！",
  "SUBTITLE_GREECE_GRE_ILN_THROUGHTHELOBBY": "^2Ilona: ^7穿过大厅！",
  "SUBTITLE_GREECE_GRE_ILN_TIMEWENTDOWN": "^2Ilona: ^7他终于倒下了！",
  "SUBTITLE_GREECE_GRE_ILN_TOTHERIGHT": "^2Ilona: ^7往右！快走！",
  "SUBTITLE_GREECE_GRE_ILN_TRUCKOUTTAWAY": "^2Ilona: ^7把这辆卡车移开！",
  "SUBTITLE_GREECE_GRE_ILN_TRYHIM": "^2Ilona: ^7试试他。",
  "SUBTITLE_GREECE_GRE_ILN_TRYSWITCHING": "^2Ilona: ^7试试切换摄像头。",
