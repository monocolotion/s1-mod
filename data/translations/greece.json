  "SUBTITLE_GREECE_GRE_ILN_WHEREISSUPPRESS": "^2Ilona: ^7压制火力在哪？",
  "SUBTITLE_GREECE_GRE_ILN_WINDOWGROUNDFLOOR": "^2Ilona: ^7窗户！一楼！",
  "SUBTITLE_GREECE_GRE_ILN_WINDOWSECONDFLOOR": "^2Ilona: ^7窗户！二楼！",
  "SUBTITLE_GREECE_GRE_ILN_YOULHAVETODO": "^2Ilona: ^7你得拉近镜头才能好好扫描。",
  "SUBTITLE_GREECE_GRE_ILN_YOUTAPPEDTHECAMERA": "^2Gideon: ^7米切尔，你接入了摄像头信号？",
  "SUBTITLE_GREECE_GRE_IRS_TEAMIDONTNEEDTO": "^2Irons: ^7队员们，不用我提醒你们这次任务有多重要。哈迪斯应对四年前的核袭击负责。",
  "SUBTITLE_GREECE_GRE_IRS_WEBRINGHIMDOWNWE": "^2Irons: ^7我们抓住他，就能摧毁整个KVA网络。容不得半点差错。完成任务。",
  "SUBTITLE_GREECE_GRE_PRP_CANYOUREPEAT": "^2Prophet: ^7托雷斯——能重复吗？",
  "SUBTITLE_GREECE_GRE_PRP_CONVOYISFOURX": "^2Prophet: ^7Bravo，哈迪斯的车队距离目标点还有四分钟。",
  "SUBTITLE_GREECE_GRE_PRP_GOODHUNTING": "^2Prophet: ^7明白！请注意，更多KVA正在接近！",
  "SUBTITLE_GREECE_GRE_PRP_HADESINBOUNDMINUTE": "^2Prophet: ^7Bravo，哈迪斯正在接近！",
  "SUBTITLE_GREECE_GRE_PRP_INTIATEUPLINK": "^2Gideon: ^7关键人物正在靠近。标记他。",
  "SUBTITLE_GREECE_GRE_PRP_KEYMANHASLEFTAREA": "^2Prophet: ^7各台注意，关键人物已离开该区域。",
  "SUBTITLE_GREECE_GRE_PRP_LOCALPOLICE": "^2Prophet: ^7各台注意，当地警方已加入追捕。",
  "SUBTITLE_GREECE_GRE_PRP_REQUESTMEDS": "^2Prophet: ^7收到，Bravo。请求医护兵。",
  "SUBTITLE_GREECE_GRE_PRP_TWOMIKESOUT": "^2Prophet: ^7Bravo，哈迪斯的车队还有两分钟到达。",
  "SUBTITLE_GREECE_GRE_PRP_UPLINKISGOOD": "^2Prophet: ^7上行链路正常。",
  "SUBTITLE_GREECE_GRE_SCZ_ATLASWEARE": "^2Torres: ^7阿特拉斯，我们正在18街的风车附近设置路障，还有——",
  "SUBTITLE_GREECE_GRE_SCZ_OFFICERSDOWN": "^2Torres: ^7有人倒了！有人倒了！风车里有狙击手！",
  "SUBTITLE_GREECE_GRE_SCZ_RPGBYTRUCK": "^2Torres: ^7找到里弗斯——他有毒刺导弹。",
  "SUBTITLE_GREECE_GRK_GDN_ABODYDOUBLE": "^2Gideon: ^7替身身上装了遥控炸弹！有人受伤了！重复——有人受伤了！",
  "SUBTITLE_GREECE_GRK_GDN_ALPHAATTHEDOOR": "^2Gideon: ^7Alpha准备破门。",
  "SUBTITLE_GREECE_GRK_GDN_ALPHAHASEYES": "^2Gideon: ^7收到。哈迪斯刚进入会议中心。",
  "SUBTITLE_GREECE_GRK_GDN_ALPHAINPOSITION": "^2Gideon: ^7Alpha就位。待命。",
  "SUBTITLE_GREECE_GRK_GDN_ALPHAYOLO": "^2Gideon: ^7Alpha行动。",
  "SUBTITLE_GREECE_GRK_GDN_ATRIUMISCLEAR": "^2Gideon: ^7中庭安全。",
  "SUBTITLE_GREECE_GRK_GDN_BUTWEHAVE": "^2Gideon: ^7但我们有一件货物要送到——",
  "SUBTITLE_GREECE_GRK_GDN_CLEARALPHASETTING": "^2Gideon: ^7安全。Alpha前往破门点。",
