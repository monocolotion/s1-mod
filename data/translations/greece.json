  "SUBTITLE_GREECE_GRK_ILN_HOLDFIREUNTILINSIDE": "^2Ilona: ^7进去之前别开火。",
  "SUBTITLE_GREECE_GRK_ILN_IFYOUVEGOTACLEAR": "^2Ilona: ^7米切尔，干掉两个。Alpha负责清扫。",
  "SUBTITLE_GREECE_GRK_ILN_IGONNASAVEYOU": "^2Ilona: ^7好了——带你离开这里。",
  "SUBTITLE_GREECE_GRK_ILN_IJUSTCONFIRMEDHAD": "^2Ilona: ^7身份确认——哈迪斯阵亡。我重复——哈迪斯阵亡。",
  "SUBTITLE_GREECE_GRK_ILN_ILLCLEAROUTTHE": "^2Ilona: ^7我去清理后面。",
  "SUBTITLE_GREECE_GRK_ILN_IMLOOKINGFOR": "^2Ilona: ^7我在找市场。我想我迷路了。",
  "SUBTITLE_GREECE_GRK_ILN_INITIATEMUTECHARGE": "^2Ilona: ^7听我信号启动——现在。",
  "SUBTITLE_GREECE_GRK_ILN_ITHASTORECHARGE": "^2Ilona: ^7需要充电！",
  "SUBTITLE_GREECE_GRK_ILN_ITSCLEARALPHA": "^2Ilona: ^7安全了。Alpha，前进。",
  "SUBTITLE_GREECE_GRK_ILN_IVELOSTVISUAL": "^2Ilona: ^7我看不到他了！吉迪恩！吉迪恩，如果你能听到，跟上哈迪斯！",
  "SUBTITLE_GREECE_GRK_ILN_JUMPTHEGUN": "^2Ilona: ^7该死，你提前开枪了！Alpha，上！上！",
  "SUBTITLE_GREECE_GRK_ILN_KILLCONFIRMED": "^2Ilona: ^7击杀确认。",
  "SUBTITLE_GREECE_GRK_ILN_LETITRECHARGE": "^2Ilona: ^7让它充电！",
  "SUBTITLE_GREECE_GRK_ILN_LINEUPHADES": "^2Ilona: ^7等我的信号再开火。",
  "SUBTITLE_GREECE_GRK_ILN_MANDOWNTHEY": "^2Ilona: ^7有人倒了！他们抓住了吉迪恩！",
  "SUBTITLE_GREECE_GRK_ILN_MINEYMINEMINE": "^2Ilona: ^7这个是我的。",
  "SUBTITLE_GREECE_GRK_ILN_MITCHELGETINTOPOS": "^2Ilona: ^7米切尔！就位！",
  "SUBTITLE_GREECE_GRK_ILN_MITCHELLHURRYUP": "^2Ilona: ^7米切尔，快点！",
  "SUBTITLE_GREECE_GRK_ILN_MITCHELLMOVETHE": "^2Ilona: ^7米切尔，把WASP移到建筑的玻璃侧。",
  "SUBTITLE_GREECE_GRK_ILN_MITCHELLONME": "^2Ilona: ^7收到，先知。米切尔！跟我来！",
  "SUBTITLE_GREECE_GRK_ILN_MITCHELLSHOOTHADES": "^2Ilona: ^7米切尔，开枪打哈迪斯！",
  "SUBTITLE_GREECE_GRK_ILN_MITCHELLTRIPTHECAR": "^2Ilona: ^7米切尔，触发汽车警报。",
  "SUBTITLE_GREECE_GRK_ILN_MITCHELLWAITUNTIL": "^2Ilona: ^7米切尔！等拿到情报再说！",
  "SUBTITLE_GREECE_GRK_ILN_MITCHTELLGETMOVING": "^2Ilona: ^7米切尔，快走！",
  "SUBTITLE_GREECE_GRK_ILN_MITCHWHENYOURREADY": "^2Ilona: ^7Alpha，等待WASP。米切尔，准备好了就行动。",
  "SUBTITLE_GREECE_GRK_ILN_MUTECHARGEEXPIRE": "^2Ilona: ^7静音炸药失效了！该死！KVA知道我们在这里了！",
  "SUBTITLE_GREECE_GRK_ILN_NEXTIMEWAITIDIOT": "^2Ilona: ^7该死。下次给我们信号，米切尔。",
  "SUBTITLE_GREECE_GRK_ILN_NICEWORK": "^2Ilona: ^7干得好。",
  "SUBTITLE_GREECE_GRK_ILN_NOW": "^2Ilona: ^7干掉他。",
  "SUBTITLE_GREECE_GRK_ILN_NOWMITCHELL": "^2Ilona: ^7现在，米切尔！",
  "SUBTITLE_GREECE_GRK_ILN_NOWTAKETHEONE": "^2Ilona: ^7米切尔，准备提供掩护火力。",
  "SUBTITLE_GREECE_GRK_ILN_ONEOFTHEGUARD": "^2Ilona: ^7有个守卫警觉了！杀了他，米切尔！",
  "SUBTITLE_GREECE_GRK_ILN_OUTOFTHEWAY": "^2Ilona: ^7让开！进去呆着！",
  "SUBTITLE_GREECE_GRK_ILN_PATROLTAKEHIM": "^2Ilona: ^7巡逻队——干掉他。",
  "SUBTITLE_GREECE_GRK_ILN_POPYOURSONICS": "^2Ilona: ^7米切尔！释放声波武器！",
  "SUBTITLE_GREECE_GRK_ILN_PROPHETKEEPEYES": "^2Ilona: ^7先知保持监视。如果有变数就通知。",
  "SUBTITLE_GREECE_GRK_ILN_PROPHETPLEASECLARIFY": "^2Ilona: ^7明白，先知。加快脚步，Alpha。别错过这场大戏。",
  "SUBTITLE_GREECE_GRK_ILN_PROPHETSAFEHOUSEIS": "^2Ilona: ^7先知，安全屋安全。将监视会议中心。",
  "SUBTITLE_GREECE_GRK_ILN_PROPHETWASPREADY": "^2Ilona: ^7先知，WASP准备发射。",
  "SUBTITLE_GREECE_GRK_ILN_PUTONYOUREXOSUIT": "^2Ilona: ^7米切尔，穿上外骨骼。我来组装WASP。",
  "SUBTITLE_GREECE_GRK_ILN_REMEMBERNOONE": "^2Ilona: ^7记住，你的击杀不能被任何人看到。",
  "SUBTITLE_GREECE_GRK_ILN_REMEMBERTHECHARGE": "^2Ilona: ^7炸药只提供有限范围的掩护。快速清理他们。",
  "SUBTITLE_GREECE_GRK_ILN_REMINDMENOT": "^2Ilona: ^7干得好。",
  "SUBTITLE_GREECE_GRK_ILN_ROCKETSTAKEEM": "^2Ilona: ^7火箭弹！干掉它们！",
  "SUBTITLE_GREECE_GRK_ILN_ROGERTHATROGER": "^2Ilona: ^7明白！",
  "SUBTITLE_GREECE_GRK_ILN_ROLLINGTHEYES": "^2Ilona: ^7等等。正在标记目标。",
  "SUBTITLE_GREECE_GRK_ILN_SHITFINDCOVER": "^2Ilona: ^7找掩护！",
  "SUBTITLE_GREECE_GRK_ILN_SHITKVA": "^2Ilona: ^7KVA来袭！",
  "SUBTITLE_GREECE_GRK_ILN_SHITWENEED": "^2Ilona: ^7操！我们得走了！",
  "SUBTITLE_GREECE_GRK_ILN_SHOOTBACKTOFRONT": "^2Ilona: ^7从后往前打。这样没人看见。",
  "SUBTITLE_GREECE_GRK_ILN_SHOOTHEEYES": "^2Ilona: ^7两个守卫在监视庭院，米切尔。干掉他们。",
  "SUBTITLE_GREECE_GRK_ILN_SHOOTINTHEBACK": "^2Ilona: ^7先干掉掉队的，然后向前推进。",
  "SUBTITLE_GREECE_GRK_ILN_SHOOTTHEDRONES": "^2Ilona: ^7电磁脉冲能干掉它们！",
  "SUBTITLE_GREECE_GRK_ILN_SHOOTTHOSEIN": "^2Ilona: ^7先干掉后面那些掉队的。",
  "SUBTITLE_GREECE_GRK_ILN_SLOPPYBUTYOUGOT": "^2Ilona: ^7有点毛躁。但你搞定他了。",
  "SUBTITLE_GREECE_GRK_ILN_STUNEEMWITH": "^2Ilona: ^7用声波武器震晕他们！",
  "SUBTITLE_GREECE_GRK_ILN_TAKEEMOUT": "^2Ilona: ^7米切尔，我来报目标。打那两个在警戒位的。",
  "SUBTITLE_GREECE_GRK_ILN_TAKEHIMMITCHELL": "^2Ilona: ^7干掉他，米切尔！",
  "SUBTITLE_GREECE_GRK_ILN_TAKETHEDRONE": "^2Ilona: ^7抓无人机，米切尔！",
  "SUBTITLE_GREECE_GRK_ILN_TAKETHEDRONEEARS": "^2Ilona: ^7抓无人机，米切尔。我来监听哈迪斯的会议。",
  "SUBTITLE_GREECE_GRK_ILN_TAKETHESHOT": "^2Ilona: ^7开枪，米切尔。",
  "SUBTITLE_GREECE_GRK_ILN_TAKETHOSEDRONES": "^2Ilona: ^7用声波武器对付那些无人机，米切尔！",
  "SUBTITLE_GREECE_GRK_ILN_TARGETDOWN": "^2Ilona: ^7很好，米切尔。",
  "SUBTITLE_GREECE_GRK_ILN_THANKSBUDDY": "^2Ilona: ^7谢了。",
  "SUBTITLE_GREECE_GRK_ILN_THATCLEAREDTHEM": "^2Ilona: ^7这下清干净了。",
  "SUBTITLE_GREECE_GRK_ILN_THATSITWASP": "^2Ilona: ^7就是现在。WASP，开枪，开枪！",
  "SUBTITLE_GREECE_GRK_ILN_THATSNOTYOURTARGET": "^2Ilona: ^7那不是你的目标！",
  "SUBTITLE_GREECE_GRK_ILN_THATSOURTICKET": "^2Ilona: ^7那是我们进去的门票。Bravo行动。",
  "SUBTITLE_GREECE_GRK_ILN_THATWASSOME": "^2Ilona: ^7干得好。",
  "SUBTITLE_GREECE_GRK_ILN_THEREALHADES": "^2Ilona: ^7真正的哈迪斯就在附近，吉迪恩！不能跟丢他！",
  "SUBTITLE_GREECE_GRK_ILN_THEREGOTAVISUAL": "^2Ilona: ^7那里。盯住哈迪斯了。真希望现在就能干掉他。",
  "SUBTITLE_GREECE_GRK_ILN_THESETOURISTS": "^2Ilona: ^7这些游客需要离开！",
  "SUBTITLE_GREECE_GRK_ILN_THESOURCETRUCK": "^2Ilona: ^7那是哈迪斯！各台前往拦截！",
  "SUBTITLE_GREECE_GRK_ILN_THROUGHHERE": "^2Ilona: ^7从这走！",
  "SUBTITLE_GREECE_GRK_ILN_TIGHTENITUP": "^2Ilona: ^7收紧点，米切尔。",
  "SUBTITLE_GREECE_GRK_ILN_TIMETOGEARUP": "^2Ilona: ^7整装。",
  "SUBTITLE_GREECE_GRK_ILN_TRYYOURSONICS": "^2Ilona: ^7用声波武器试试！",
  "SUBTITLE_GREECE_GRK_ILN_TWOINTHENEXT": "^2Ilona: ^7隔壁房间有两个。",
  "SUBTITLE_GREECE_GRK_ILN_TWOONFTHEROOF": "^2Ilona: ^7打楼梯顶端的两个。",
  "SUBTITLE_GREECE_GRK_ILN_UPSTAIRS": "^2Ilona: ^7楼上。",
  "SUBTITLE_GREECE_GRK_ILN_USEYOUREMP": "^2Ilona: ^7用电磁脉冲手雷！",
  "SUBTITLE_GREECE_GRK_ILN_USEYOURSONICS": "^2Ilona: ^7用声波武器！",
  "SUBTITLE_GREECE_GRK_ILN_WAITFORTHEFINISH": "^2Ilona: ^7等他们说完。",
  "SUBTITLE_GREECE_GRK_ILN_WASPTOSTART": "^2Ilona: ^7快点。",
  "SUBTITLE_GREECE_GRK_ILN_WATCHYOURAIM": "^2Ilona: ^7注意平民！",
  "SUBTITLE_GREECE_GRK_ILN_WEAPONSREADY": "^2Ilona: ^7武器就绪。",
  "SUBTITLE_GREECE_GRK_ILN_WECANTKEEP": "^2Ilona: ^7我们不能一直耽误下去！",
  "SUBTITLE_GREECE_GRK_ILN_WENEEDTOPULL": "^2Ilona: ^7需要把KVA从那道门引开，好让Alpha进入。触发汽车警报。",
  "SUBTITLE_GREECE_GRK_ILN_WERECRAWLINGWITH": "^2Gideon: ^7到处都是KVA！继续向前推进，拦截哈迪斯！",
  "SUBTITLE_GREECE_GRK_ILN_WEREGOINGTOLOSE": "^2Ilona: ^7我们要跟丢他了，米切尔。",
  "SUBTITLE_GREECE_GRK_ILN_WESEEHIM": "^2Ilona: ^7该你了，米切尔。",
  "SUBTITLE_GREECE_GRK_ILN_WHATAREYOUDOING": "^2Ilona: ^7米切尔，你在等什么？",
  "SUBTITLE_GREECE_GRK_ILN_WHATDOESIRONSKNOW": "^2Ilona: ^7艾恩斯知道什么？",
  "SUBTITLE_GREECE_GRK_ILN_WHATUSTHAPPENED": "^2Ilona: ^7刚才发生了什么？Alpha！报告！",
  "SUBTITLE_GREECE_GRK_ILN_WHYHAVENTYOU": "^2Ilona: ^7我们时间不多了。",
  "SUBTITLE_GREECE_GRK_ILN_YOUHAVEANOTHER": "^2Ilona: ^7Alpha稍等，里面有监视者。",
  "SUBTITLE_GREECE_GRK_ILN_YOUJUSTBLEW": "^2Ilona: ^7你暴露了我们的身份！",
  "SUBTITLE_GREECE_GRK_ILN_YOULLNEEDTONEUT": "^2Ilona: ^7等守卫靠近了再干掉。",
  "SUBTITLE_GREECE_GRK_ILN_YOUNEARLYBLEW": "^2Ilona: ^7你差点把定时器搞砸了。得快一点。",
  "SUBTITLE_GREECE_GRK_ILN_YOUNEEDTOBEFASTER": "^2Ilona: ^7你得比这更快。",
  "SUBTITLE_GREECE_GRK_ILN_YOURDATEIS": "^2Gideon: ^7切换到Bravo视角。米切尔——你的妻子在等你。",
  "SUBTITLE_GREECE_GRK_ILN_YOUREXOSISFIT": "^2Ilona: ^7你的外骨骼装了城市套件。在人群里遇到麻烦？别犹豫，直接释放声波武器。",
  "SUBTITLE_GREECE_GRK_KVA_ALLSTATIONSWILL": "^2KVA Soldier: ^7所有站点将按时确保安全，长官。您的会议将不受干扰。",
  "SUBTITLE_GREECE_GRK_KVA_DAMINPROPDISENGAGE": "^2Ilona: ^7该死！先知，米切尔脱离了！哈迪斯跑了！",
  "SUBTITLE_GREECE_GRK_KVA_DIMITRIISTHAT": "^2KVA Soldier: ^7迪米特里！那辆车走了没有？",
  "SUBTITLE_GREECE_GRK_KVA_HEY": "^2KVA Soldier: ^7嘿！",
  "SUBTITLE_GREECE_GRK_KVA_HEYYOU": "^2KVA Soldier: ^7嘿——你！",
  "SUBTITLE_GREECE_GRK_KVA_IDONTCARE": "^2KVA Soldier: ^7我不在乎！把车开走，否则我们帮你。",
  "SUBTITLE_GREECE_GRK_KVA_ITSNOTHERE": "^2KVA Soldier: ^7不在这里。走。现在。",
  "SUBTITLE_GREECE_GRK_KVA_KEEPTHEMAWAYFROHELL": "^2KVA Soldier: ^7别让他们靠近哈迪斯！",
  "SUBTITLE_GREECE_GRK_KVA_LETSCHECKIT": "^2KVA Soldier: ^7去看看！",
  "SUBTITLE_GREECE_GRK_KVA_MAKESURETHE": "^2KVA Soldier One: ^7我已经确保狙击手就位了。他们会每十五分钟检查一次。",
  "SUBTITLE_GREECE_GRK_KVA_MYAPOLOGIES": "^2KVA Captain: ^7抱歉。",
  "SUBTITLE_GREECE_GRK_KVA_NOSTAYWHEREYOU": "^2KVA Soldier: ^7不。呆在原地，我要报告。",
  "SUBTITLE_GREECE_GRK_KVA_NOTHINGHERE": "^2KVA Soldier: ^7什么都没有。",
  "SUBTITLE_GREECE_GRK_KVA_NOWEHAVENT": "^2KVA Soldier: ^7不，我们还没有。是的，长官。",
  "SUBTITLE_GREECE_GRK_KVA_PROTECTHADESATALL": "^2KVA Soldier: ^7不惜一切代价保护哈迪斯！",
  "SUBTITLE_GREECE_GRK_KVA_REPORT": "^2KVA Soldier: ^7迪米特里！报告！",
  "SUBTITLE_GREECE_GRK_KVA_SHITINTRUDERS": "^2KVA Soldier: ^7操！有入侵者！",
  "SUBTITLE_GREECE_GRK_KVA_SOMETHINGSNOTRIGHT": "^2KVA Soldier: ^7有点不对劲——我要报告。",
  "SUBTITLE_GREECE_GRK_KVA_THATPOSES": "^2KVA Captain: ^7那风险太大了。我们不知道货物是否足够稳定——",
  "SUBTITLE_GREECE_GRK_KVA_THEREISABLIND": "^2KVA Soldier Two: ^7从这个制高点看，这条巷子里有个盲区。在那个角落安排一个人来覆盖。至于外围，我们在每层和停车场都布置了巡逻队，这里和这里。会议一结束，一辆装甲—",
  "SUBTITLE_GREECE_GRK_KVA_THERETHEYAREWHAT": "^2KVA Soldier: ^7他们在那里！",
  "SUBTITLE_GREECE_GRK_KVA_THEYAINTGONNAGETIM": "^2KVA Soldier: ^7别让他们过去！",
  "SUBTITLE_GREECE_GRK_KVA_THEYREINTHESAFE": "^2KVA Soldier: ^7他们在安全屋里！",
  "SUBTITLE_GREECE_GRK_KVA_THISDOCTORWILL": "^2KVA Captain: ^7这个医生什么都不会说。",
  "SUBTITLE_GREECE_GRK_KVA_THISISPRIVATE": "^2KVA Soldier: ^7这是私人财产。你必须离开。",
  "SUBTITLE_GREECE_GRK_KVA_THISSTREETISOFF": "^2KVA Soldier: ^7这条街禁止通行。快走。",
  "SUBTITLE_GREECE_GRK_KVA_UNDERSTOOD": "^2KVA Soldier: ^7明白。",
  "SUBTITLE_GREECE_GRK_KVA_WHATTHE": "^2KVA Soldier: ^7什么——？",
  "SUBTITLE_GREECE_GRK_KVA_YOUCANNOTPARK": "^2KVA Soldier: ^7你不能停在这里！",
  "SUBTITLE_GREECE_GRK_PRP_50METERSTOTARGET": "^2Prophet: ^7距离目标200米。",
  "SUBTITLE_GREECE_GRK_PRP_ABORTTHEMISSION": "^2Prophet: ^7各台中止！守卫被惊动了！重复，中止！",
  "SUBTITLE_GREECE_GRK_PRP_ALLSTATIONSABORT": "^2Prophet: ^7各台中止！Bravo已暴露。重复，Bravo已暴露。",
  "SUBTITLE_GREECE_GRK_PRP_ALLSTATIONSBEADVISED": "^2Prophet: ^7各台注意，看起来哈迪斯要开始会议了。",
  "SUBTITLE_GREECE_GRK_PRP_ALLSTATSCONVOYSOUTH": "^2Prophet: ^7各台注意，哈迪斯车队正向南行驶！",
  "SUBTITLE_GREECE_GRK_PRP_ALLTEAMSBEADVISED": "^2Prophet: ^7各队注意，Bravo在待命。可能有情况。",
  "SUBTITLE_GREECE_GRK_PRP_ALLTEAMSONHADES": "^2Prophet: ^7各队注意哈迪斯！各队注意哈迪斯！卡车正向南行驶！",
  "SUBTITLE_GREECE_GRK_PRP_ALLTEAMSVEHICLE": "^2Prophet: ^7各队——卡车离开南车库。是哈迪斯！哈迪斯在移动！",
  "SUBTITLE_GREECE_GRK_PRP_ALPHANEEDSAWASP": "^2Prophet: ^7Alpha需要WASP打击。直接击毙。",
  "SUBTITLE_GREECE_GRK_PRP_ALPHAREPORT": "^2Prophet: ^7Alpha报告！",
  "SUBTITLE_GREECE_GRK_PRP_BEADVISEDKVAHAS": "^2Prophet: ^7Bravo，请注意，KVA已包围你们的位置。",
  "SUBTITLE_GREECE_GRK_PRP_BEADVISEDKVAONROOF": "^2Prophet: ^7请注意，KVA在移动。",
  "SUBTITLE_GREECE_GRK_PRP_BRAVEOTAKETHEGUARD": "^2Prophet: ^7Bravo，干掉守卫。",
  "SUBTITLE_GREECE_GRK_PRP_BRAVEYOUNEED": "^2Prophet: ^7Bravo，你得快点。",
  "SUBTITLE_GREECE_GRK_PRP_BRAVOALPHAISWAITING": "^2Prophet: ^7Bravo，Alpha在等WASP。",
  "SUBTITLE_GREECE_GRK_PRP_BRAVOBEADVISED": "^2Prophet: ^7Bravo，请注意，时间紧迫。",
  "SUBTITLE_GREECE_GRK_PRP_BRAVOBEADVISEDTHE": "^2Prophet: ^7Bravo，请注意，机会窗口正在关闭。",
  "SUBTITLE_GREECE_GRK_PRP_BRAVOBEADVISEDYOUR": "^2Prophet: ^7Bravo，请注意，你们落后了！",
  "SUBTITLE_GREECE_GRK_PRP_BRAVOHASENTERED": "^2Prophet: ^7Alpha，请注意。Bravo已到达目标点。",
  "SUBTITLE_GREECE_GRK_PRP_BRAVOSTANDBY": "^2Prophet: ^7Bravo待命。Alpha确认已盯住目标。",
  "SUBTITLE_GREECE_GRK_PRP_BRAVOSTAYONHIM": "^2Prophet: ^7Bravo，你的目标在移动。跟住他。",
  "SUBTITLE_GREECE_GRK_PRP_BRAVOTHEREISNOTIME": "^2Prophet: ^7Bravo——没时间闲逛了。跟住你的目标。",
  "SUBTITLE_GREECE_GRK_PRP_BRAVOWELOSTCOM": "^2Prophet: ^7Bravo，我们与Alpha失去联系了。正在尝试修复。",
  "SUBTITLE_GREECE_GRK_PRP_BRAVOYOUARELAGGING": "^2Prophet: ^7Bravo，你落后了——跟上来。",
  "SUBTITLE_GREECE_GRK_PRP_BRAVOYOUNEEDTOGET": "^2Prophet: ^7Bravo，你得行动了！",
  "SUBTITLE_GREECE_GRK_PRP_BRAVOYOURENOT": "^2Prophet: ^7Bravo，你没在动。什么情况？",
  "SUBTITLE_GREECE_GRK_PRP_BRAVOYOURETAKING": "^2Prophet: ^7Bravo，你等太久了。KVA被惊动了——中止！",
  "SUBTITLE_GREECE_GRK_PRP_BRAVOYOURTARGETIS": "^2Prophet: ^7Bravo，目标在移动。跟住他。",
  "SUBTITLE_GREECE_GRK_PRP_BRAVOYOURWINDOW": "^2Prophet: ^7Bravo，机会窗口正在关闭。干掉守卫。",
  "SUBTITLE_GREECE_GRK_PRP_COPYTHAT": "^2Prophet: ^7收到。",
  "SUBTITLE_GREECE_GRK_PRP_COPYTHATALPHA": "^2Prophet: ^7各队，任务开始。",
  "SUBTITLE_GREECE_GRK_PRP_COPYTHATBRAVOPROCEED": "^2Prophet: ^7收到，Bravo。Alpha可以进入第二阶段。",
  "SUBTITLE_GREECE_GRK_PRP_COPYTHATSTANDBY": "^2Prophet: ^7收到。等待WASP。",
  "SUBTITLE_GREECE_GRK_PRP_COPYTHATTRANSLATION": "^2Prophet: ^7收到。翻译信号正常。",
  "SUBTITLE_GREECE_GRK_PRP_COVERISBLOWN": "^2Prophet: ^7各台，彻底暴露！中止！中止！中止！",
  "SUBTITLE_GREECE_GRK_PRP_ENEMYTECHINBOUND": "^2Prophet: ^7各台——KVA科技装备正在进入。",
  "SUBTITLE_GREECE_GRK_PRP_KILLCONFIRMED": "^2Prophet: ^7干得好，Bravo。",
  "SUBTITLE_GREECE_GRK_PRP_KVACLOSINGIN": "^2Prophet: ^7Bravo，KVA来袭。有平民在场。",
  "SUBTITLE_GREECE_GRK_PRP_LOADINGUPPARTYBUS": "^2Gideon: ^7收到。Alpha正在装卡车。",
  "SUBTITLE_GREECE_GRK_PRP_POSITIVEID": "^2Prophet: ^7通讯信号匹配KVA。他就是我们的关键人物。",
  "SUBTITLE_GREECE_GRK_PRP_SANCHEZOVEROVER": "^2Prophet: ^7托雷斯——能重复吗？",
  "SUBTITLE_GREECE_GRK_PRP_THATSAKILL": "^2Prophet: ^7确认击杀。",
  "SUBTITLE_GREECE_GRK_PRP_WAITINGONBRAVO": "^2Prophet: ^7等待Bravo。",
  "SUBTITLE_GREECE_GRK_PRP_WASPINPOSITION": "^2Prophet: ^7Alpha的卡车正在驶向大门。",
  "SUBTITLE_GREECE_GRK_PRP_WASPISAIRBORNE": "^2Prophet: ^7WASP已升空。",
  "SUBTITLE_GREECE_GRK_PRP_WASPYOUVEBEENSPOTTED": "^2Prophet: ^7WASP你被发现了！中止任务！我重复，中止任务！",
  "SUBTITLE_GREECE_GRK_SAN_MANDOWNSNIPERBELL": "^2Torres: ^7有人倒了！有人倒了！钟楼里有狙击手！",
  "SUBTITLE_GREECE_GRK_SAN_WEHAVECONTACTYO": "^2Torres: ^7我们在钟楼接触敌人——",
  "SUBTITLE_GREECE_GRK_SLD_SHITHESRIGGED": "^2Drelick: ^7操！他身上有炸弹。离开房间！",
  "SUBTITLE_GREECE_GRP_ILN_ZOOMINMITCH": "^2Prophet: ^7放大那个会议室。",
  "VARIABLE_GRENADE_AREA_DENIAL": "区域封锁手雷",
  "VARIABLE_GRENADE_CLUSTER_GRENADE": "集束手雷",
