  "SUBTITLE_GREECE_GRE_ILN_WATCHTHECORNERS": "^2Ilona: ^7注意角落！",
  "SUBTITLE_GREECE_GRE_ILN_WATCHTHEFLAMES": "^2Ilona: ^7注意火焰！",
